msgid "Init Embed Posts – Stylish, Fast, Portable"
msgstr "Init Embed Posts – Đẹp mắt, Nhanh chóng, Dễ nhúng mọi nơi"

msgid "Embed any WordPress post externally like a Twitter Card. No iframe, no shortcode – just pure magic."
msgstr "Nhúng bài viết WordPress như Twitter Card – không cần iframe hay shortcode, chỉ thuần HTML + JS."

msgid "Embed this post"
msgstr "Nhúng bài viết này"

msgid "Show featured image"
msgstr "Hiển thị ảnh bìa bài viết"

msgid "Show image"
msgstr "Hiển thị ảnh"

msgid "Theme:"
msgstr "Giao diện:"

msgid "Copy"
msgstr "Sao chép"

msgid "Embed code copied!"
msgstr "Đã sao chép mã nhúng!"

msgid "Copy embed code"
msgstr "Sao chép mã nhúng"

msgid "Init Embed Posts Settings"
msgstr "Cài đặt Init Embed Posts"

msgid "Init Embed Posts"
msgstr "Init Embed Posts"

msgid "Auto-insert embed button at"
msgstr "Tự động chèn nút nhúng tại"

msgid "After the title"
msgstr "Sau tiêu đề"

msgid "Before the content"
msgstr "Trước nội dung"

msgid "After the content"
msgstr "Sau nội dung"

msgid "After the product meta"
msgstr "Sau thông tin sản phẩm"

msgid "Alternatively, you can insert the embed button manually by adding the <code>[init_embed_code]</code> shortcode anywhere inside the loop."
msgstr "Hoặc bạn có thể tự chèn nút nhúng bằng cách thêm shortcode <code>[init_embed_code]</code> vào bất kỳ vị trí nào trong vòng lặp."

msgid "Show post meta"
msgstr "Hiển thị thông tin bài viết"

msgid "Show review"
msgstr "Hiển thị đánh giá"

msgid "Light"
msgstr "Sáng"

msgid "Dark"
msgstr "Tối"

msgid "Auto"
msgstr "Tự động"

msgid "Post not found"
msgstr "Không tìm thấy bài viết"

msgid "Product not found"
msgstr "Không tìm thấy sản phẩm"

msgid "Gallery image limit"
msgstr "Số ảnh gallery tối đa"

msgid "Maximum number of images shown in the gallery row of an embed card (1–10)."
msgstr "Số lượng ảnh tối đa hiển thị ở hàng gallery trong thẻ nhúng (1–10)."

msgid "Default embed theme"
msgstr "Giao diện mặc định cho embed"

msgid "Theme pre-selected in the embed code generator modal. Visitors can still override it per embed via data-theme."
msgstr "Giao diện được chọn sẵn trong hộp thoại tạo mã nhúng. Người dùng vẫn có thể ghi đè riêng cho từng embed qua thuộc tính data-theme."
